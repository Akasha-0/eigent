# Eigent - Environment Variables Template
# Copy this file to .env and fill in your values

# Database
POSTGRES_PASSWORD=CHANGE_ME_generate_a_strong_random_password

# Chat Share Security
CHAT_SHARE_SECRET_KEY=CHANGE_ME_generate_a_strong_random_key_32chars
CHAT_SHARE_SALT=CHANGE_ME

# Token expiration (optional)
CHAT_SHARE_EXPIRATION_SECONDS=86400
